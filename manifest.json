{
  "manifest_version": 3,
  "name": "CuteBlock",
  "description": "Replace annoying ads with cute animals.",
  "version": "0.2.3",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "CuteBlock",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "optional_host_permissions": [
    "https://random.dog/*",
    "https://dog.ceo/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.jpg",
        "filters/*.txt"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
